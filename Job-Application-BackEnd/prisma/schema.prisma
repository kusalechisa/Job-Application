generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  Admin
  Applicant
}

enum ApplicationStatus {
  Applied
  Reviewed
  Accepted
  Rejected
}

model Account {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  role        Role     @default(Applicant)
  status      String   @default("active")

  applicant   Applicant?
  jobsPosted  Job[]    @relation("PostedJobs")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Applicant {
  id          String   @id @default(uuid())
  accountId   String   @unique

  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  firstName        String?
  lastName         String?
  middleName       String?
  dateOfBirth      DateTime?
  nationality      String?
  gender           String?
  maritalStatus    String?
  profilePicture   String?

  phone            String?
  alternativePhone String?
  address          String?
  city             String?
  subCity          String?
  region           String?

  profession          String?
  currentJobTitle     String?
  yearsOfExperience   Int?
  employmentStatus    String?
  portfolioUrl        String?
  linkedinUrl         String?
  githubUrl           String?

  skills          String[] @default([])
  languages       String[] @default([])
  technicalSkills String[] @default([])
  softSkills      String[] @default([])

  resume          String?

  /// Cumulative Grade Point Average (scale varies by institution; stored as decimal)
  cgpa            Float?
  /// Exit / qualifying exam score out of 100
  exitExamScore   Float?

  applications    Application[]
  education       Education[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Education {
  id            String   @id @default(uuid())

  applicantId   String
  applicant     Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  highestEducation String?
  university       String?
  college          String?
  fieldOfStudy     String?
  graduationYear   Int?
  cgpa             Float?
  exitExamScore    Float?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Job {
  id              String   @id @default(uuid())

  title           String
  description     String
  company         String
  location        String

  salary          String?
  type            String?
  workType        String?
  employmentType  String?

  responsibilities String?
  requirements    String?
  deadline        DateTime?

  status          String   @default("draft")
  featured        Boolean  @default(false)

  postedById      String
  postedBy        Account  @relation("PostedJobs", fields: [postedById], references: [id], onDelete: Cascade)

  applications    Application[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Application {
  id           String   @id @default(uuid())

  jobId        String
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  applicantId  String
  applicant    Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  status       ApplicationStatus @default(Applied)

  resume       String?

  appliedAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([jobId])
  @@index([applicantId])
}