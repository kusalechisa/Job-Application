modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["replitmail:1.0.0"]

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
JWT_SECRET = "replit_jwt_secret_dev_only"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Job-Application-FrontEnd && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Job-Application-BackEnd && npm run start"
waitForPort = 5002

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5002
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 5002

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd Job-Application-BackEnd && npm install && npx prisma generate && node ./src/app.js"]
build = ["bash", "-c", "cd Job-Application-FrontEnd && npm install && npm run build"]
